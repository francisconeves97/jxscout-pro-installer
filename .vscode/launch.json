{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Debug CLI (TypeScript)",
			"program": "${workspaceFolder}/src/cli.tsx",
			"runtimeExecutable": "bun",
			"runtimeArgs": ["--inspect-wait"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": ["${workspaceFolder}/dist/**/*.js"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug CLI (Compiled)",
			"program": "${workspaceFolder}/dist/cli.js",
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "build"
		}
	]
}
